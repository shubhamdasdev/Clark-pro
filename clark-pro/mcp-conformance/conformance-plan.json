{
  "$schema": "https://schemas.clark.pro/v1/mcp-conformance-plan.schema.json",
  "schemaVersion": 1,
  "planId": "clark.mcp.conformance",
  "revision": "1.0.0",
  "protocolRevision": "2025-11-25",
  "sdkBaseline": {"package": "@modelcontextprotocol/sdk", "version": "1.29.0", "policy": "pinned-v1-production-baseline"},
  "owners": [
    {"area": "connect", "primaryRole": "W6 Connect Lead", "backupRole": "Developer Platform Lead", "artifactDuty": "Own hostile-server fixtures, adapter quarantine, and compatibility evidence."},
    {"area": "bridge", "primaryRole": "W6 Bridge Lead", "backupRole": "Domain Lead", "artifactDuty": "Own hostile-client fixtures, canonical command reuse, session and scope evidence."},
    {"area": "security", "primaryRole": "Security Lead", "backupRole": "Privacy Lead", "artifactDuty": "Own canaries, origin/auth abuse, severity, incident escalation, and redaction review."},
    {"area": "quality", "primaryRole": "Quality Lead", "backupRole": "Release Lead", "artifactDuty": "Own deterministic execution, artifact retention, regression policy, and release blocking."},
    {"area": "incident", "primaryRole": "Security Lead", "backupRole": "Release Lead", "artifactDuty": "Coordinate credential rotation, quarantine, reconciliation, disclosure, and retest after a critical failure."}
  ],
  "blockingPolicy": {
    "critical": "block_release_and_quarantine",
    "high": "block_capability_promotion",
    "medium": "block_when_protocol_must",
    "secretCanary": "block_release_rotate_canary_review_logs",
    "duplicateEffect": "block_release_reconcile_and_incident_review",
    "quarantineTriggers": ["protocol_corruption", "schema_abuse", "secret_canary", "scope_violation", "unbounded_resource", "untrusted_instruction", "replay_side_effect", "origin_failure", "auth_failure"]
  },
  "cases": [
