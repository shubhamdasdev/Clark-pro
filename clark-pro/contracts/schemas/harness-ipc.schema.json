{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.clark.pro/v1/harness-ipc.schema.json",
  "title": "Clark Harness IPC Message",
  "oneOf": [
    { "$ref": "#/$defs/request" },
    { "$ref": "#/$defs/response" },
    { "$ref": "#/$defs/event" }
  ],
  "$defs": {
    "request": {
      "type": "object",
      "required": ["schemaVersion", "kind", "requestId", "deadlineAt", "command"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "kind": { "const": "request" },
        "requestId": { "$ref": "common.schema.json#/$defs/id" },
        "deadlineAt": { "$ref": "common.schema.json#/$defs/timestamp" },
        "command": {
          "oneOf": [
            { "$ref": "#/$defs/statusCommand" },
            { "$ref": "#/$defs/workspaceEnsureCommand" },
            { "$ref": "#/$defs/loopStartCommand" },
            { "$ref": "#/$defs/ideaReviseCommand" },
            { "$ref": "#/$defs/runGetCommand" },
            { "$ref": "#/$defs/runListCommand" },
            { "$ref": "#/$defs/approvalResolveCommand" },
            { "$ref": "#/$defs/capabilityListCommand" },
            { "$ref": "#/$defs/bridgeStatusCommand" }
          ]
        }
      },
      "additionalProperties": false
    },
    "statusCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "harness.status" },
        "payload": { "type": "object", "additionalProperties": false }
      },
      "additionalProperties": false
    },
    "workspaceEnsureCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "workspace.ensure" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "name"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "name": { "type": "string", "minLength": 1, "maxLength": 160 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "loopStartCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "loop.start" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "projectId", "ideaText", "idempotencyKey"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "projectId": { "$ref": "common.schema.json#/$defs/id" },
            "ideaText": { "type": "string", "minLength": 20, "maxLength": 12000 },
            "idempotencyKey": { "type": "string", "minLength": 8, "maxLength": 256 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "ideaReviseCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "idea.revise" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "parentRunId", "ideaText", "revisionReason", "idempotencyKey"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "parentRunId": { "$ref": "common.schema.json#/$defs/id" },
            "ideaText": { "type": "string", "minLength": 20, "maxLength": 12000 },
            "revisionReason": { "type": "string", "minLength": 3, "maxLength": 1000 },
            "idempotencyKey": { "type": "string", "minLength": 8, "maxLength": 256 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "runGetCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "run.get" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "runId"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "runId": { "$ref": "common.schema.json#/$defs/id" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "runListCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "run.list" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "limit"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "limit": { "type": "integer", "minimum": 1, "maximum": 50 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "approvalResolveCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "approval.resolve" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "runId", "approvalId", "decision", "idempotencyKey"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "runId": { "$ref": "common.schema.json#/$defs/id" },
            "approvalId": { "$ref": "common.schema.json#/$defs/id" },
            "decision": { "enum": ["approve", "reject"] },
            "reason": { "type": "string", "maxLength": 1000 },
            "idempotencyKey": { "type": "string", "minLength": 8, "maxLength": 256 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "capabilityListCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "capability.list" },
        "payload": {
          "type": "object",
          "required": ["workspaceId"],
          "properties": { "workspaceId": { "$ref": "common.schema.json#/$defs/id" } },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "bridgeStatusCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "bridge.status" },
        "payload": {
          "type": "object",
          "required": ["workspaceId"],
          "properties": { "workspaceId": { "$ref": "common.schema.json#/$defs/id" } },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "response": {
      "type": "object",
      "required": ["schemaVersion", "kind", "requestId", "method", "ok"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "kind": { "const": "response" },
        "requestId": { "$ref": "common.schema.json#/$defs/id" },
        "method": { "enum": ["harness.status", "workspace.ensure", "loop.start", "idea.revise", "run.get", "run.list", "approval.resolve", "capability.list", "bridge.status"] },
        "ok": { "type": "boolean" },
        "result": {
          "oneOf": [
            { "$ref": "#/$defs/statusResult" },
            { "$ref": "#/$defs/workspaceResult" },
            { "$ref": "#/$defs/loopStartResult" },
            { "$ref": "#/$defs/runSummary" },
            { "$ref": "#/$defs/runListResult" },
            { "$ref": "#/$defs/capabilityListResult" },
            { "$ref": "#/$defs/bridgeStatusResult" }
          ]
        },
        "error": { "$ref": "#/$defs/error" }
      },
      "oneOf": [
        { "properties": { "ok": { "const": true } }, "required": ["result"], "not": { "required": ["error"] } },
        { "properties": { "ok": { "const": false } }, "required": ["error"], "not": { "required": ["result"] } }
      ],
      "additionalProperties": false
    },
    "error": {
      "type": "object",
      "required": ["code", "message", "retryable"],
      "properties": {
        "code": { "enum": ["invalid_request", "deadline_exceeded", "not_found", "conflict", "policy_denied", "not_ready", "internal"] },
        "message": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "retryable": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "event": {
      "type": "object",
      "required": ["schemaVersion", "kind", "sequence", "eventType", "emittedAt", "payload"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "kind": { "const": "event" },
        "sequence": { "type": "integer", "minimum": 1 },
        "eventType": { "enum": ["harness.ready", "harness.recovering", "run.updated", "approval.required"] },
        "emittedAt": { "$ref": "common.schema.json#/$defs/timestamp" },
        "payload": {
          "oneOf": [
            { "$ref": "#/$defs/harnessReadyPayload" },
            { "$ref": "#/$defs/harnessRecoveringPayload" },
            { "$ref": "#/$defs/runUpdatedPayload" },
            { "$ref": "#/$defs/approvalRequiredPayload" }
          ]
        }
      },
      "additionalProperties": false
    },
    "statusResult": {
      "type": "object",
      "required": ["state", "protocolVersion", "database", "activeRuns", "recoveredRuns"],
      "properties": {
        "state": { "enum": ["ready", "recovering"] },
        "protocolVersion": { "const": 1 },
        "database": {
          "type": "object",
          "required": ["journalMode", "eventCount"],
          "properties": {
            "journalMode": { "const": "wal" },
            "eventCount": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "activeRuns": { "type": "integer", "minimum": 0 },
        "recoveredRuns": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "workspaceResult": {
      "type": "object",
      "required": ["workspaceId", "created", "aggregateVersion"],
      "properties": {
        "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
        "created": { "type": "boolean" },
        "aggregateVersion": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "loopStartResult": {
      "type": "object",
      "required": ["run", "deduplicated"],
      "properties": {
        "run": { "$ref": "#/$defs/runSummary" },
        "deduplicated": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "runListResult": {
      "type": "object",
      "required": ["runs"],
      "properties": {
        "runs": { "type": "array", "items": { "$ref": "#/$defs/runSummary" }, "maxItems": 50 }
      },
      "additionalProperties": false
    },
    "capabilityListResult": {
      "type": "object",
      "required": ["capabilities"],
      "properties": {
        "capabilities": {
          "type": "array",
          "maxItems": 100,
          "items": {
            "type": "object",
            "required": ["id", "version", "name", "state", "transport", "actionClass", "networkDomains", "credentialScopes", "limitations"],
            "properties": {
              "id": { "$ref": "common.schema.json#/$defs/id" },
              "version": { "$ref": "common.schema.json#/$defs/semver" },
              "name": { "type": "string", "minLength": 1, "maxLength": 160 },
              "state": { "enum": ["registered", "healthy", "degraded", "offline", "revoked"] },
              "transport": { "enum": ["library", "mcp_stdio", "mcp_streamable_http", "http_api", "local_process", "browser"] },
              "actionClass": { "$ref": "common.schema.json#/$defs/actionClass" },
              "networkDomains": { "type": "array", "items": { "type": "string", "format": "hostname" }, "uniqueItems": true },
              "credentialScopes": { "type": "array", "items": { "$ref": "common.schema.json#/$defs/permissionScope" }, "uniqueItems": true },
              "limitations": { "type": "array", "items": { "type": "string", "maxLength": 500 } }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "bridgeStatusResult": {
      "type": "object",
      "required": ["state", "transport", "host", "configured", "clientId", "expiresAt", "tools", "resources"],
      "properties": {
        "state": { "enum": ["disabled", "starting", "ready", "failed"] },
        "transport": { "const": "streamable_http" },
        "host": { "const": "127.0.0.1" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "configured": { "type": "boolean" },
        "clientId": { "type": ["string", "null"] },
        "expiresAt": { "type": ["string", "null"], "format": "date-time" },
        "tools": { "type": "array", "items": { "$ref": "common.schema.json#/$defs/id" }, "uniqueItems": true },
        "resources": { "type": "array", "items": { "type": "string", "format": "uri" }, "uniqueItems": true }
      },
      "additionalProperties": false
    },
    "harnessReadyPayload": {
      "type": "object",
      "required": ["protocolVersion", "recoveredRuns"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "recoveredRuns": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "harnessRecoveringPayload": {
      "type": "object",
      "required": ["reason", "restartAttempt"],
      "properties": {
        "reason": { "type": "string", "minLength": 1, "maxLength": 500 },
        "restartAttempt": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "runUpdatedPayload": {
      "type": "object",
      "required": ["runId", "state"],
      "properties": {
        "runId": { "$ref": "common.schema.json#/$defs/id" },
        "state": { "enum": ["planned", "running", "recovering", "waiting_approval", "completed", "failed", "cancelled"] }
      },
      "additionalProperties": false
    },
    "approvalRequiredPayload": {
      "type": "object",
      "required": ["runId", "approvalId", "subjectRef"],
      "properties": {
        "runId": { "$ref": "common.schema.json#/$defs/id" },
        "approvalId": { "$ref": "common.schema.json#/$defs/id" },
        "subjectRef": { "$ref": "common.schema.json#/$defs/id" }
      },
      "additionalProperties": false
    },
    "assetSummary": {
      "type": "object",
      "required": ["artifactId", "versionId", "contentHash", "text"],
      "properties": {
        "artifactId": { "$ref": "common.schema.json#/$defs/id" },
        "versionId": { "$ref": "common.schema.json#/$defs/id" },
        "contentHash": { "$ref": "common.schema.json#/$defs/contentHash" },
        "text": { "type": "string", "maxLength": 20000 }
      },
      "additionalProperties": false
    },
    "approvalSummary": {
      "type": "object",
      "required": ["approvalId", "subjectRef", "state", "reason"],
      "properties": {
        "approvalId": { "$ref": "common.schema.json#/$defs/id" },
        "subjectRef": { "$ref": "common.schema.json#/$defs/id" },
        "state": { "enum": ["waiting", "approved", "rejected", "invalidated"] },
        "reason": { "type": "string", "minLength": 1, "maxLength": 1000 }
      },
      "additionalProperties": false
    },
    "runSummary": {
      "type": "object",
      "required": ["runId", "workspaceId", "projectId", "loopRevision", "state", "activeStepId", "idea", "eventCount", "recoveredFromCheckpoint", "updatedAt"],
      "properties": {
        "runId": { "$ref": "common.schema.json#/$defs/id" },
        "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
        "projectId": { "$ref": "common.schema.json#/$defs/id" },
        "loopRevision": { "$ref": "common.schema.json#/$defs/revisionRef" },
        "rootRunId": { "$ref": "common.schema.json#/$defs/id" },
        "parentRunId": { "$ref": "common.schema.json#/$defs/id" },
        "revisionNumber": { "type": "integer", "minimum": 1 },
        "revisionReason": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "state": { "enum": ["planned", "running", "recovering", "waiting_approval", "completed", "failed", "cancelled"] },
        "activeStepId": { "type": ["string", "null"] },
        "idea": { "$ref": "#/$defs/assetSummary" },
        "analysis": { "$ref": "#/$defs/assetSummary" },
        "draft": { "$ref": "#/$defs/assetSummary" },
        "approval": { "$ref": "#/$defs/approvalSummary" },
        "eventCount": { "type": "integer", "minimum": 1 },
        "recoveredFromCheckpoint": { "type": "boolean" },
        "updatedAt": { "$ref": "common.schema.json#/$defs/timestamp" }
      },
      "additionalProperties": false
    }
  }
}
