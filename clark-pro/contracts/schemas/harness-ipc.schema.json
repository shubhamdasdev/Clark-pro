{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.clark.pro/v1/harness-ipc.schema.json",
  "title": "Clark Harness IPC Message",
  "oneOf": [
    { "$ref": "#/$defs/request" },
    { "$ref": "#/$defs/response" },
    { "$ref": "#/$defs/event" }
  ],
  "$defs": {
    "request": {
      "type": "object",
      "required": ["schemaVersion", "kind", "requestId", "deadlineAt", "command"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "kind": { "const": "request" },
        "requestId": { "$ref": "common.schema.json#/$defs/id" },
        "deadlineAt": { "$ref": "common.schema.json#/$defs/timestamp" },
        "command": {
          "oneOf": [
            { "$ref": "#/$defs/statusCommand" },
            { "$ref": "#/$defs/workspaceEnsureCommand" },
            { "$ref": "#/$defs/loopStartCommand" },
            { "$ref": "#/$defs/ideaReviseCommand" },
            { "$ref": "#/$defs/runGetCommand" },
            { "$ref": "#/$defs/runListCommand" },
            { "$ref": "#/$defs/approvalResolveCommand" },
            { "$ref": "#/$defs/memoryProposeCommand" },
            { "$ref": "#/$defs/memoryResolveCommand" },
            { "$ref": "#/$defs/memoryCorrectCommand" },
            { "$ref": "#/$defs/memoryListCommand" },
            { "$ref": "#/$defs/memoryRetrieveCommand" },
            { "$ref": "#/$defs/toolPackageListCommand" },
            { "$ref": "#/$defs/toolPackageGetCommand" },
            { "$ref": "#/$defs/toolPackageEvaluateCommand" },
            { "$ref": "#/$defs/toolPackageResolveCommand" },
            { "$ref": "#/$defs/capabilityListCommand" },
            { "$ref": "#/$defs/bridgeStatusCommand" }
          ]
        }
      },
      "additionalProperties": false
    },
    "statusCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "harness.status" },
        "payload": { "type": "object", "additionalProperties": false }
      },
      "additionalProperties": false
    },
    "workspaceEnsureCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "workspace.ensure" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "name"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "name": { "type": "string", "minLength": 1, "maxLength": 160 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "loopStartCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "loop.start" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "projectId", "ideaText", "idempotencyKey"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "projectId": { "$ref": "common.schema.json#/$defs/id" },
            "ideaText": { "type": "string", "minLength": 20, "maxLength": 12000 },
            "idempotencyKey": { "type": "string", "minLength": 8, "maxLength": 256 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "ideaReviseCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "idea.revise" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "parentRunId", "ideaText", "revisionReason", "idempotencyKey"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "parentRunId": { "$ref": "common.schema.json#/$defs/id" },
            "ideaText": { "type": "string", "minLength": 20, "maxLength": 12000 },
            "revisionReason": { "type": "string", "minLength": 3, "maxLength": 1000 },
            "idempotencyKey": { "type": "string", "minLength": 8, "maxLength": 256 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "runGetCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "run.get" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "runId"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "runId": { "$ref": "common.schema.json#/$defs/id" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "runListCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "run.list" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "limit"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "limit": { "type": "integer", "minimum": 1, "maximum": 50 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "approvalResolveCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "approval.resolve" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "runId", "approvalId", "decision", "idempotencyKey"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "runId": { "$ref": "common.schema.json#/$defs/id" },
            "approvalId": { "$ref": "common.schema.json#/$defs/id" },
            "decision": { "enum": ["approve", "reject"] },
            "reason": { "type": "string", "maxLength": 1000 },
            "idempotencyKey": { "type": "string", "minLength": 8, "maxLength": 256 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "memoryScope": {
      "type": "object",
      "required": ["workspaceId"],
      "properties": {
        "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
        "projectId": { "$ref": "common.schema.json#/$defs/id" },
        "platform": { "$ref": "common.schema.json#/$defs/id" },
        "loopId": { "$ref": "common.schema.json#/$defs/id" },
        "accountConnectionId": { "$ref": "common.schema.json#/$defs/id" }
      },
      "additionalProperties": false
    },
    "memoryProposeCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "memory.propose" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "layer", "statement", "evidence", "contradictions", "confidence", "scope", "sensitivity", "retrievalPolicy", "idempotencyKey"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "layer": { "enum": ["identity", "semantic", "episodic", "procedural", "performance"] },
            "statement": { "type": "string", "minLength": 3, "maxLength": 4000 },
            "evidence": { "type": "array", "items": { "$ref": "common.schema.json#/$defs/evidenceRef" }, "minItems": 1, "maxItems": 20 },
            "contradictions": { "type": "array", "items": { "$ref": "common.schema.json#/$defs/evidenceRef" }, "maxItems": 20 },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "scope": { "$ref": "#/$defs/memoryScope" },
            "sensitivity": { "$ref": "common.schema.json#/$defs/sensitivity" },
            "retrievalPolicy": { "enum": ["default", "explicit_only", "never_send_to_model"] },
            "expiresAt": { "$ref": "common.schema.json#/$defs/timestamp" },
            "idempotencyKey": { "type": "string", "minLength": 8, "maxLength": 256 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "memoryResolveCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "memory.resolve" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "memoryId", "action", "reason", "idempotencyKey"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "memoryId": { "$ref": "common.schema.json#/$defs/id" },
            "action": { "enum": ["promote", "reject", "dispute", "forget"] },
            "reason": { "type": "string", "minLength": 3, "maxLength": 1000 },
            "idempotencyKey": { "type": "string", "minLength": 8, "maxLength": 256 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "memoryCorrectCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "memory.correct" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "memoryId", "statement", "reason", "idempotencyKey"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "memoryId": { "$ref": "common.schema.json#/$defs/id" },
            "statement": { "type": "string", "minLength": 3, "maxLength": 4000 },
            "reason": { "type": "string", "minLength": 3, "maxLength": 1000 },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "scope": { "$ref": "#/$defs/memoryScope" },
            "sensitivity": { "$ref": "common.schema.json#/$defs/sensitivity" },
            "retrievalPolicy": { "enum": ["default", "explicit_only", "never_send_to_model"] },
            "expiresAt": { "$ref": "common.schema.json#/$defs/timestamp" },
            "idempotencyKey": { "type": "string", "minLength": 8, "maxLength": 256 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "memoryListCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "memory.list" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "limit", "includeForgotten"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "limit": { "type": "integer", "minimum": 1, "maximum": 100 },
            "includeForgotten": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "memoryRetrieveCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "memory.retrieve" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "query", "purpose", "destination", "scope", "maxSensitivity", "includeExplicitOnly", "limit", "idempotencyKey"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "query": { "type": "string", "minLength": 1, "maxLength": 1000 },
            "purpose": { "type": "string", "minLength": 3, "maxLength": 500 },
            "destination": { "enum": ["creator_view", "local_model", "remote_model"] },
            "scope": { "$ref": "#/$defs/memoryScope" },
            "maxSensitivity": { "$ref": "common.schema.json#/$defs/sensitivity" },
            "includeExplicitOnly": { "type": "boolean" },
            "limit": { "type": "integer", "minimum": 1, "maximum": 20 },
            "idempotencyKey": { "type": "string", "minLength": 8, "maxLength": 256 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "toolPackageListCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "tool_package.list" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "limit"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "limit": { "type": "integer", "minimum": 1, "maximum": 100 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "toolPackageGetCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "tool_package.get" },
        "payload": { "$ref": "#/$defs/toolPackageIdentity" }
      },
      "additionalProperties": false
    },
    "toolPackageEvaluateCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "tool_package.evaluate" },
        "payload": { "$ref": "#/$defs/toolPackageIdentity" }
      },
      "additionalProperties": false
    },
    "toolPackageResolveCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "tool_package.resolve" },
        "payload": {
          "type": "object",
          "required": ["workspaceId", "toolPackageId", "revision", "action", "reason", "idempotencyKey"],
          "properties": {
            "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
            "toolPackageId": { "$ref": "common.schema.json#/$defs/id" },
            "revision": { "$ref": "common.schema.json#/$defs/semver" },
            "action": { "enum": ["activate", "rollback"] },
            "reason": { "type": "string", "minLength": 3, "maxLength": 1000 },
            "idempotencyKey": { "type": "string", "minLength": 8, "maxLength": 256 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "capabilityListCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "capability.list" },
        "payload": {
          "type": "object",
          "required": ["workspaceId"],
          "properties": { "workspaceId": { "$ref": "common.schema.json#/$defs/id" } },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "bridgeStatusCommand": {
      "type": "object",
      "required": ["method", "payload"],
      "properties": {
        "method": { "const": "bridge.status" },
        "payload": {
          "type": "object",
          "required": ["workspaceId"],
          "properties": { "workspaceId": { "$ref": "common.schema.json#/$defs/id" } },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "response": {
      "type": "object",
      "required": ["schemaVersion", "kind", "requestId", "method", "ok"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "kind": { "const": "response" },
        "requestId": { "$ref": "common.schema.json#/$defs/id" },
        "method": { "enum": ["harness.status", "workspace.ensure", "loop.start", "idea.revise", "run.get", "run.list", "approval.resolve", "memory.propose", "memory.resolve", "memory.correct", "memory.list", "memory.retrieve", "tool_package.list", "tool_package.get", "tool_package.evaluate", "tool_package.resolve", "capability.list", "bridge.status"] },
        "ok": { "type": "boolean" },
        "result": {
          "oneOf": [
            { "$ref": "#/$defs/statusResult" },
            { "$ref": "#/$defs/workspaceResult" },
            { "$ref": "#/$defs/loopStartResult" },
            { "$ref": "#/$defs/runSummary" },
            { "$ref": "#/$defs/runListResult" },
            { "$ref": "#/$defs/memoryMutationResult" },
            { "$ref": "#/$defs/memoryListResult" },
            { "$ref": "#/$defs/memoryRetrievalResult" },
            { "$ref": "#/$defs/toolPackageSummary" },
            { "$ref": "#/$defs/toolPackageListResult" },
            { "$ref": "#/$defs/capabilityListResult" },
            { "$ref": "#/$defs/bridgeStatusResult" }
          ]
        },
        "error": { "$ref": "#/$defs/error" }
      },
      "oneOf": [
        { "properties": { "ok": { "const": true } }, "required": ["result"], "not": { "required": ["error"] } },
        { "properties": { "ok": { "const": false } }, "required": ["error"], "not": { "required": ["result"] } }
      ],
      "additionalProperties": false
    },
    "error": {
      "type": "object",
      "required": ["code", "message", "retryable"],
      "properties": {
        "code": { "enum": ["invalid_request", "deadline_exceeded", "not_found", "conflict", "policy_denied", "not_ready", "internal"] },
        "message": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "retryable": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "event": {
      "type": "object",
      "required": ["schemaVersion", "kind", "sequence", "eventType", "emittedAt", "payload"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "kind": { "const": "event" },
        "sequence": { "type": "integer", "minimum": 1 },
        "eventType": { "enum": ["harness.ready", "harness.recovering", "run.updated", "approval.required", "memory.updated", "tool_package.updated"] },
        "emittedAt": { "$ref": "common.schema.json#/$defs/timestamp" },
        "payload": {
          "oneOf": [
            { "$ref": "#/$defs/harnessReadyPayload" },
            { "$ref": "#/$defs/harnessRecoveringPayload" },
            { "$ref": "#/$defs/runUpdatedPayload" },
            { "$ref": "#/$defs/approvalRequiredPayload" },
            { "$ref": "#/$defs/memoryUpdatedPayload" },
            { "$ref": "#/$defs/toolPackageUpdatedPayload" }
          ]
        }
      },
      "additionalProperties": false
    },
    "statusResult": {
      "type": "object",
      "required": ["state", "protocolVersion", "database", "activeRuns", "recoveredRuns"],
      "properties": {
        "state": { "enum": ["ready", "recovering"] },
        "protocolVersion": { "const": 1 },
        "database": {
          "type": "object",
          "required": ["journalMode", "eventCount"],
          "properties": {
            "journalMode": { "const": "wal" },
            "eventCount": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "activeRuns": { "type": "integer", "minimum": 0 },
        "recoveredRuns": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "workspaceResult": {
      "type": "object",
      "required": ["workspaceId", "created", "aggregateVersion"],
      "properties": {
        "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
        "created": { "type": "boolean" },
        "aggregateVersion": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "loopStartResult": {
      "type": "object",
      "required": ["run", "deduplicated"],
      "properties": {
        "run": { "$ref": "#/$defs/runSummary" },
        "deduplicated": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "runListResult": {
      "type": "object",
      "required": ["runs"],
      "properties": {
        "runs": { "type": "array", "items": { "$ref": "#/$defs/runSummary" }, "maxItems": 50 }
      },
      "additionalProperties": false
    },
    "memorySummary": {
      "type": "object",
      "required": ["memoryId", "workspaceId", "layer", "statement", "evidence", "contradictions", "confidence", "scope", "sensitivity", "retrievalPolicy", "state", "retrievalEligible", "createdBy", "searchDerivativesDeleted", "updatedAt"],
      "properties": {
        "memoryId": { "$ref": "common.schema.json#/$defs/id" },
        "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
        "layer": { "enum": ["identity", "semantic", "episodic", "procedural", "performance"] },
        "statement": { "type": "string", "minLength": 1, "maxLength": 4000 },
        "evidence": { "type": "array", "items": { "$ref": "common.schema.json#/$defs/evidenceRef" }, "maxItems": 20 },
        "contradictions": { "type": "array", "items": { "$ref": "common.schema.json#/$defs/evidenceRef" }, "maxItems": 20 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "scope": { "$ref": "#/$defs/memoryScope" },
        "sensitivity": { "$ref": "common.schema.json#/$defs/sensitivity" },
        "retrievalPolicy": { "enum": ["default", "explicit_only", "never_send_to_model"] },
        "state": { "enum": ["proposed", "active", "disputed", "expired", "rejected", "forgotten"] },
        "retrievalEligible": { "type": "boolean" },
        "createdBy": { "enum": ["creator", "reflection_agent", "import"] },
        "supersedesMemoryId": { "$ref": "common.schema.json#/$defs/id" },
        "replacementMemoryId": { "$ref": "common.schema.json#/$defs/id" },
        "decisionId": { "$ref": "common.schema.json#/$defs/id" },
        "expiresAt": { "$ref": "common.schema.json#/$defs/timestamp" },
        "searchDerivativesDeleted": { "type": "boolean" },
        "matchedTerms": { "type": "integer", "minimum": 0 },
        "updatedAt": { "$ref": "common.schema.json#/$defs/timestamp" }
      },
      "additionalProperties": false
    },
    "memoryMutationResult": {
      "type": "object",
      "required": ["memory", "deduplicated"],
      "properties": {
        "memory": { "$ref": "#/$defs/memorySummary" },
        "deduplicated": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "memoryListResult": {
      "type": "object",
      "required": ["memories"],
      "properties": { "memories": { "type": "array", "items": { "$ref": "#/$defs/memorySummary" }, "maxItems": 100 } },
      "additionalProperties": false
    },
    "memoryRetrievalResult": {
      "type": "object",
      "required": ["retrievalId", "queryHash", "purpose", "destination", "memories", "policyRevisionId", "deduplicated"],
      "properties": {
        "retrievalId": { "$ref": "common.schema.json#/$defs/id" },
        "queryHash": { "$ref": "common.schema.json#/$defs/contentHash" },
        "purpose": { "type": "string", "minLength": 1, "maxLength": 500 },
        "destination": { "enum": ["creator_view", "local_model", "remote_model"] },
        "memories": { "type": "array", "items": { "$ref": "#/$defs/memorySummary" }, "maxItems": 20 },
        "policyRevisionId": { "$ref": "common.schema.json#/$defs/id" },
        "deduplicated": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "toolPackageIdentity": {
      "type": "object",
      "required": ["workspaceId", "toolPackageId", "revision"],
      "properties": {
        "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
        "toolPackageId": { "$ref": "common.schema.json#/$defs/id" },
        "revision": { "$ref": "common.schema.json#/$defs/semver" }
      },
      "additionalProperties": false
    },
    "toolPackageGate": {
      "type": "object",
      "required": ["id", "label", "status", "evidence"],
      "properties": {
        "id": { "$ref": "common.schema.json#/$defs/id" },
        "label": { "type": "string", "minLength": 1, "maxLength": 160 },
        "status": { "enum": ["pass", "pending", "block"] },
        "evidence": { "type": "string", "minLength": 1, "maxLength": 1000 }
      },
      "additionalProperties": false
    },
    "toolPackageSummary": {
      "type": "object",
      "required": ["toolPackageId", "revision", "name", "description", "publisherName", "publisherTrust", "sourceRevision", "sourceHash", "manifestHash", "state", "installed", "trustBasis", "statusReason", "preferredPath", "stableInterfaceCount", "componentCounts", "evidenceStatus", "activationEligible", "gates", "limitations", "updatedAt"],
      "properties": {
        "toolPackageId": { "$ref": "common.schema.json#/$defs/id" },
        "revision": { "$ref": "common.schema.json#/$defs/semver" },
        "name": { "type": "string", "minLength": 1, "maxLength": 160 },
        "description": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "publisherName": { "type": "string", "minLength": 1, "maxLength": 200 },
        "publisherTrust": { "enum": ["bundled_verified", "verified", "community_unverified", "local_development"] },
        "sourceRevision": { "type": "string", "minLength": 1, "maxLength": 256 },
        "sourceHash": { "$ref": "common.schema.json#/$defs/contentHash" },
        "manifestHash": { "$ref": "common.schema.json#/$defs/contentHash" },
        "state": { "enum": ["discovered", "blocked_upstream", "quarantined", "testing", "active", "suspended", "failed", "rolled_back"] },
        "installed": { "type": "boolean" },
        "trustBasis": { "enum": ["source_review_pending", "source_reviewed", "signed_release", "sandbox_verified", "bundled_verified", "developer_mode"] },
        "statusReason": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "preferredPath": { "enum": ["mcp", "headless_cli", "http_api", "library", "wasm_component", "local_sidecar", "file_handoff", "browser_automation", "forked_vendor"] },
        "stableInterfaceCount": { "type": "integer", "minimum": 0 },
        "componentCounts": {
          "type": "object",
          "required": ["adapters", "capabilities", "skills", "converters", "uiContributions"],
          "properties": {
            "adapters": { "type": "integer", "minimum": 0 },
            "capabilities": { "type": "integer", "minimum": 0 },
            "skills": { "type": "integer", "minimum": 0 },
            "converters": { "type": "integer", "minimum": 0 },
            "uiContributions": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "evidenceStatus": { "$ref": "event-payloads.schema.json#/$defs/toolPackageRevisionStateChanged/properties/evidenceStatus" },
        "activationEligible": { "type": "boolean" },
        "rollbackRevision": { "$ref": "common.schema.json#/$defs/semver" },
        "gates": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/toolPackageGate" } },
        "limitations": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 1000 } },
        "updatedAt": { "$ref": "common.schema.json#/$defs/timestamp" }
      },
      "additionalProperties": false
    },
    "toolPackageListResult": {
      "type": "object",
      "required": ["toolPackages"],
      "properties": { "toolPackages": { "type": "array", "items": { "$ref": "#/$defs/toolPackageSummary" }, "maxItems": 100 } },
      "additionalProperties": false
    },
    "capabilityListResult": {
      "type": "object",
      "required": ["capabilities"],
      "properties": {
        "capabilities": {
          "type": "array",
          "maxItems": 100,
          "items": {
            "type": "object",
            "required": ["id", "version", "name", "state", "transport", "actionClass", "networkDomains", "credentialScopes", "limitations"],
            "properties": {
              "id": { "$ref": "common.schema.json#/$defs/id" },
              "version": { "$ref": "common.schema.json#/$defs/semver" },
              "name": { "type": "string", "minLength": 1, "maxLength": 160 },
              "state": { "enum": ["registered", "healthy", "degraded", "offline", "revoked"] },
              "transport": { "enum": ["library", "mcp_stdio", "mcp_streamable_http", "http_api", "local_process", "browser"] },
              "actionClass": { "$ref": "common.schema.json#/$defs/actionClass" },
              "networkDomains": { "type": "array", "items": { "type": "string", "format": "hostname" }, "uniqueItems": true },
              "credentialScopes": { "type": "array", "items": { "$ref": "common.schema.json#/$defs/permissionScope" }, "uniqueItems": true },
              "limitations": { "type": "array", "items": { "type": "string", "maxLength": 500 } }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "bridgeStatusResult": {
      "type": "object",
      "required": ["state", "transport", "host", "configured", "clientId", "expiresAt", "tools", "resources"],
      "properties": {
        "state": { "enum": ["disabled", "starting", "ready", "failed"] },
        "transport": { "const": "streamable_http" },
        "host": { "const": "127.0.0.1" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "configured": { "type": "boolean" },
        "clientId": { "type": ["string", "null"] },
        "expiresAt": { "type": ["string", "null"], "format": "date-time" },
        "tools": { "type": "array", "items": { "$ref": "common.schema.json#/$defs/id" }, "uniqueItems": true },
        "resources": { "type": "array", "items": { "type": "string", "format": "uri" }, "uniqueItems": true }
      },
      "additionalProperties": false
    },
    "harnessReadyPayload": {
      "type": "object",
      "required": ["protocolVersion", "recoveredRuns"],
      "properties": {
        "protocolVersion": { "const": 1 },
        "recoveredRuns": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "harnessRecoveringPayload": {
      "type": "object",
      "required": ["reason", "restartAttempt"],
      "properties": {
        "reason": { "type": "string", "minLength": 1, "maxLength": 500 },
        "restartAttempt": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "runUpdatedPayload": {
      "type": "object",
      "required": ["runId", "state"],
      "properties": {
        "runId": { "$ref": "common.schema.json#/$defs/id" },
        "state": { "enum": ["planned", "running", "recovering", "waiting_approval", "completed", "failed", "cancelled"] }
      },
      "additionalProperties": false
    },
    "approvalRequiredPayload": {
      "type": "object",
      "required": ["runId", "approvalId", "subjectRef"],
      "properties": {
        "runId": { "$ref": "common.schema.json#/$defs/id" },
        "approvalId": { "$ref": "common.schema.json#/$defs/id" },
        "subjectRef": { "$ref": "common.schema.json#/$defs/id" }
      },
      "additionalProperties": false
    },
    "memoryUpdatedPayload": {
      "type": "object",
      "required": ["memoryId", "state"],
      "properties": {
        "memoryId": { "$ref": "common.schema.json#/$defs/id" },
        "state": { "enum": ["proposed", "active", "disputed", "expired", "rejected", "forgotten"] }
      },
      "additionalProperties": false
    },
    "toolPackageUpdatedPayload": {
      "type": "object",
      "required": ["toolPackageId", "revision", "state"],
      "properties": {
        "toolPackageId": { "$ref": "common.schema.json#/$defs/id" },
        "revision": { "$ref": "common.schema.json#/$defs/semver" },
        "state": { "enum": ["discovered", "blocked_upstream", "quarantined", "testing", "active", "suspended", "failed", "rolled_back"] }
      },
      "additionalProperties": false
    },
    "assetSummary": {
      "type": "object",
      "required": ["artifactId", "versionId", "contentHash", "text"],
      "properties": {
        "artifactId": { "$ref": "common.schema.json#/$defs/id" },
        "versionId": { "$ref": "common.schema.json#/$defs/id" },
        "contentHash": { "$ref": "common.schema.json#/$defs/contentHash" },
        "text": { "type": "string", "maxLength": 20000 }
      },
      "additionalProperties": false
    },
    "approvalSummary": {
      "type": "object",
      "required": ["approvalId", "subjectRef", "state", "reason"],
      "properties": {
        "approvalId": { "$ref": "common.schema.json#/$defs/id" },
        "subjectRef": { "$ref": "common.schema.json#/$defs/id" },
        "state": { "enum": ["waiting", "approved", "rejected", "invalidated"] },
        "reason": { "type": "string", "minLength": 1, "maxLength": 1000 }
      },
      "additionalProperties": false
    },
    "runSummary": {
      "type": "object",
      "required": ["runId", "workspaceId", "projectId", "loopRevision", "state", "activeStepId", "idea", "eventCount", "recoveredFromCheckpoint", "updatedAt"],
      "properties": {
        "runId": { "$ref": "common.schema.json#/$defs/id" },
        "workspaceId": { "$ref": "common.schema.json#/$defs/id" },
        "projectId": { "$ref": "common.schema.json#/$defs/id" },
        "loopRevision": { "$ref": "common.schema.json#/$defs/revisionRef" },
        "rootRunId": { "$ref": "common.schema.json#/$defs/id" },
        "parentRunId": { "$ref": "common.schema.json#/$defs/id" },
        "revisionNumber": { "type": "integer", "minimum": 1 },
        "revisionReason": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "state": { "enum": ["planned", "running", "recovering", "waiting_approval", "completed", "failed", "cancelled"] },
        "activeStepId": { "type": ["string", "null"] },
        "idea": { "$ref": "#/$defs/assetSummary" },
        "analysis": { "$ref": "#/$defs/assetSummary" },
        "draft": { "$ref": "#/$defs/assetSummary" },
        "approval": { "$ref": "#/$defs/approvalSummary" },
        "eventCount": { "type": "integer", "minimum": 1 },
        "recoveredFromCheckpoint": { "type": "boolean" },
        "updatedAt": { "$ref": "common.schema.json#/$defs/timestamp" }
      },
      "additionalProperties": false
    }
  }
}
