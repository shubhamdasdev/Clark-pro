{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.clark.pro/v1/event-stream.schema.json",
  "title": "Clark Domain Event Stream",
  "type": "object",
  "required": ["schemaVersion", "streamId", "events"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "streamId": { "$ref": "common.schema.json#/$defs/id" },
    "events": {
      "type": "array",
      "items": { "$ref": "domain-event.schema.json" },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
