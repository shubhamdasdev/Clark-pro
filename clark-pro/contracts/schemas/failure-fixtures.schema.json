{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.clark.pro/v1/failure-fixtures.schema.json",
  "title": "Clark Failure and Abuse Fixtures",
  "type": "object",
  "required": ["schemaVersion", "suiteId", "cases"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "suiteId": { "$ref": "common.schema.json#/$defs/id" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "case": {
      "type": "object",
      "required": ["id", "title", "threatIds", "initialState", "stimulus", "expectedEvents", "expectedFinalState", "forbiddenOutcomes", "invariants"],
      "properties": {
        "id": { "$ref": "common.schema.json#/$defs/id" },
        "title": { "type": "string", "minLength": 1, "maxLength": 200 },
        "threatIds": { "type": "array", "items": { "type": "string", "pattern": "^[A-Z]+-[A-Z0-9]+$" }, "minItems": 1, "uniqueItems": true },
        "initialState": { "type": "object" },
        "stimulus": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["type", "target"],
            "properties": {
              "type": { "enum": ["process_crash", "provider_response", "provider_timeout", "credential_revoke", "input_payload", "package_update", "policy_change", "event_replay", "network_disconnect", "budget_exhaustion", "user_command"] },
              "target": { "type": "string", "minLength": 1, "maxLength": 300 },
              "data": { "type": "object" }
            },
            "additionalProperties": false
          }
        },
        "expectedEvents": { "type": "array", "items": { "$ref": "common.schema.json#/$defs/eventType" }, "minItems": 1 },
        "expectedFinalState": { "type": "object", "minProperties": 1 },
        "forbiddenOutcomes": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 500 }, "minItems": 1 },
        "invariants": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 500 }, "minItems": 1 }
      },
      "additionalProperties": false
    }
  }
}
