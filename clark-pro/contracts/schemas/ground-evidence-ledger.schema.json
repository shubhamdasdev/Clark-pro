{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.clark.pro/v1/ground-evidence-ledger.schema.json",
  "title": "Clark Ground Evidence Ledger",
  "type": "object",
  "required": [
    "schemaVersion",
    "ledgerId",
    "stratum",
    "reviewedAt",
    "currentGate",
    "gateState",
    "entries",
    "signoff"
  ],
  "properties": {
    "$schema": {
      "const": "https://schemas.clark.pro/v1/ground-evidence-ledger.schema.json"
    },
    "schemaVersion": {
      "$ref": "https://schemas.clark.pro/v1/common.schema.json#/$defs/semver"
    },
    "ledgerId": {
      "const": "clark.evidence.ground"
    },
    "stratum": {
      "const": "ground"
    },
    "reviewedAt": {
      "$ref": "https://schemas.clark.pro/v1/common.schema.json#/$defs/timestamp"
    },
    "currentGate": {
      "const": "before-stratum-1-implementation"
    },
    "gateState": {
      "enum": ["open", "ready_with_explicit_risk", "closed"]
    },
    "entries": {
      "type": "array",
      "minItems": 34,
      "items": {
        "$ref": "#/$defs/entry"
      }
    },
    "signoff": {
      "$ref": "#/$defs/signoff"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "evidenceKind": {
      "enum": [
        "design_document",
        "adr",
        "schema",
        "fixture",
        "prototype",
        "automated_test",
        "expert_review",
        "observed_session",
        "design_partner_record",
        "binding_action",
        "runtime_test",
        "signoff"
      ]
    },
    "evidence": {
      "type": "object",
      "required": ["kind", "location", "claim", "result"],
      "properties": {
        "kind": {
          "$ref": "#/$defs/evidenceKind"
        },
        "location": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300,
          "pattern": "^(?!/)(?!.*\\.\\.)[A-Za-z0-9._/-]+$"
        },
        "claim": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600
        },
        "result": {
          "enum": ["pass", "pending", "fail", "not_run"]
        },
        "command": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "observedAt": {
          "$ref": "https://schemas.clark.pro/v1/common.schema.json#/$defs/timestamp"
        }
      },
      "additionalProperties": false
    },
    "entry": {
      "type": "object",
      "required": [
        "id",
        "area",
        "requirement",
        "ownerRole",
        "proofRequired",
        "result",
        "evidence",
        "acceptanceRule",
        "limitations",
        "nextAction",
        "groundBlocking",
        "releaseTarget",
        "updatedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(OBJ|CANVAS|BIZ|GROUND)-[0-9]{2}$"
        },
        "area": {
          "enum": ["objective", "canvas", "business", "delivery"]
        },
        "requirement": {
          "type": "string",
          "minLength": 5,
          "maxLength": 500
        },
        "ownerRole": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "proofRequired": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/evidenceKind"
          }
        },
        "result": {
          "enum": [
            "verified",
            "contract_verified",
            "prototype_verified",
            "defined",
            "human_evidence_pending",
            "specified_not_verified",
            "missing",
            "failed",
            "not_applicable"
          ]
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "acceptanceRule": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1200
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "nextAction": {
          "type": "string",
          "minLength": 5,
          "maxLength": 800
        },
        "groundBlocking": {
          "type": "boolean"
        },
        "releaseTarget": {
          "enum": [
            "ground",
            "stratum-1",
            "stratum-2",
            "stratum-3",
            "stratum-4",
            "stratum-5",
            "stratum-6"
          ]
        },
        "updatedAt": {
          "$ref": "https://schemas.clark.pro/v1/common.schema.json#/$defs/timestamp"
        }
      },
      "additionalProperties": false
    },
    "approval": {
      "type": "object",
      "required": ["role", "person", "decision", "at"],
      "properties": {
        "role": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "person": {
          "type": "string",
          "minLength": 2,
          "maxLength": 160
        },
        "decision": {
          "enum": ["approve", "reject", "approve_with_bounded_risk"]
        },
        "at": {
          "$ref": "https://schemas.clark.pro/v1/common.schema.json#/$defs/timestamp"
        },
        "note": {
          "type": "string",
          "maxLength": 800
        }
      },
      "additionalProperties": false
    },
    "signoff": {
      "type": "object",
      "required": ["state", "requiredRoles", "approvals"],
      "properties": {
        "state": {
          "enum": ["pending", "approved", "rejected"]
        },
        "requiredRoles": {
          "type": "array",
          "minItems": 7,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 120
          }
        },
        "approvals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/approval"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
