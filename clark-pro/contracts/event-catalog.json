      "eventType": "artifact.canonical_selected",
      "schemaVersion": 1,
      "aggregateType": "artifact",
      "payloadRef": "./schemas/event-payloads.schema.json#/$defs/canonicalSelected",
      "compatibility": "additive",
      "defaultSensitivity": "workspace",
      "mutationClass": "local_state",
      "description": "Selects a canonical version through an attributable decision."
