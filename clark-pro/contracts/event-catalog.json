      "defaultSensitivity": "personal",
      "mutationClass": "security_state",
      "description": "Records a checksum-addressed portable export that contains no raw secrets."
    },
    {
      "eventType": "project.created",
      "schemaVersion": 1,
      "aggregateType": "project",
      "payloadRef": "./schemas/event-payloads.schema.json#/$defs/projectCreated",
      "compatibility": "additive",
      "defaultSensitivity": "workspace",
      "mutationClass": "local_state",
      "description": "Creates a project within one workspace."
