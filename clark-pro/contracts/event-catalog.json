      "eventType": "source.captured",
      "schemaVersion": 1,
      "aggregateType": "artifact",
      "payloadRef": "./schemas/event-payloads.schema.json#/$defs/sourceCaptured",
      "compatibility": "additive",
      "defaultSensitivity": "personal",
      "mutationClass": "local_state",
      "description": "Stores an immutable original capture without triggering generation."
