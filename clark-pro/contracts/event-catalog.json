      "eventType": "run.failed",
      "schemaVersion": 1,
      "aggregateType": "run",
      "payloadRef": "./schemas/event-payloads.schema.json#/$defs/runStateChanged",
      "compatibility": "terminal",
      "defaultSensitivity": "workspace",
      "mutationClass": "local_state",
      "description": "Records terminal run failure with an attributable reason and recovery state.",
      "requiredCorrelation": true
