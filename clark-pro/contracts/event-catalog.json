      "eventType": "step.failed",
      "schemaVersion": 1,
      "aggregateType": "run",
      "payloadRef": "./schemas/event-payloads.schema.json#/$defs/stepStateChanged",
      "compatibility": "additive",
      "defaultSensitivity": "workspace",
      "mutationClass": "local_state",
