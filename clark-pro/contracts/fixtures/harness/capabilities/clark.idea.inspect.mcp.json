{
  "$schema": "../../../schemas/capability-manifest.schema.json",
  "schemaVersion": 1,
  "id": "clark.idea.inspect.mcp",
  "name": "Clark Bundled MCP Idea Inspector",
  "description": "Inspects explicit creator text for outcome, user, mechanism, trust, and evidence signals through a bundled deterministic MCP stdio server.",
  "version": "1.0.0",
  "publisher": {
    "id": "clark",
    "name": "Clark Pro",
    "source": "https://github.com/shubhamdasdev/Clark-pro",
    "sourceRevision": "bundled-mcp-idea-inspector-v1",
    "sourceHash": "sha256:70502852c4cc3e6f89e479019fed2f13eba7da9d31a0240135d7359bb937c8bb"
  },
  "kind": "observation",
  "transport": { "type": "mcp", "modes": ["stdio"], "serverRef": "mcp.clark.idea-inspector", "toolName": "analyze_idea" },
  "inputSchemaRef": "https://schemas.clark.pro/v1/capability-runtime.schema.json#/$defs/ideaAnalysisInput",
  "outputSchemaRef": "https://schemas.clark.pro/v1/capability-runtime.schema.json#/$defs/ideaAnalysisResult",
  "lifecycle": ["discover", "validate", "execute", "health", "revoke"],
  "permissions": {
    "actionClass": "local_transform",
    "systemScopes": [],
    "credentialScopes": [],
    "networkDomains": [],
    "fileAccess": "none",
    "requiresUserPresence": false
  },
  "egress": {
    "maximumSensitivity": "confidential",
    "declaredFields": [],
    "retentionPolicy": "none",
    "trainingPolicy": "not_used"
  },
  "async": { "mode": "sync", "cancellable": true, "observable": true, "reconnectByExternalId": false },
  "idempotency": { "strategy": "not_applicable", "reconciliation": "not_required" },
  "cost": { "quoteSupport": "exact", "metering": "none", "currency": "USD" },
  "reliability": { "timeoutSeconds": 15, "retryPolicy": "safe_transient_only", "maxAttempts": 2, "healthCheck": "non_mutating_active", "schemaDriftBehavior": "block" },
  "ui": { "renderer": "idea.analysis", "previewSafe": true, "supportsProgress": false, "supportsDiff": true },
  "limitations": [
    { "code": "lexical-signals-only", "description": "The bundled inspector detects explicit lexical signals; it does not judge market value, research truth, originality, or creator fit.", "fallback": "manual" }
  ]
}
